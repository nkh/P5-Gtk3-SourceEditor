<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="theme_light" _name="Light" version="1.0">
  <style name="text" foreground="#2E3436" background="#FDF6E3"/>
  <style name="selection" foreground="#FFFFFF" background="#4A90D9"/>
  <style name="current-line" background="#EEE8D5"/>
  <style name="line-numbers" foreground="#BABDB6" background="#FDF6E3"/>
  <style name="bracket-match" foreground="#2E3436" background="#D3D7CF"/>
  <style name="def:keyword" foreground="#073642" bold="true"/>
  <style name="def:string" foreground="#2AA198"/>
  <style name="def:comment" foreground="#93A1A1" italic="true"/>
  <style name="def:type" foreground="#268BD2"/>
  <style name="def:variable" foreground="#657B83"/>
  <style name="def:function" foreground="#268BD2"/>
  <style name="def:number" foreground="#D33682"/>
</style-scheme>
